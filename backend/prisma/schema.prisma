generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}


// USER
model User {
  id           String            @id @default(uuid())
  username     String
  email        String            @unique
  password     String
  role         Role              @default(student)
  createdAt    DateTime          @default(now())
  fname        String?
  lname        String?
  interactions UserInteraction[]
  interests    UserInterest[]
  bookmarks    Bookmark[]
}


// COURSE
model Course {
  id           String            @id @default(uuid())
  title        String
  description  String
  category     String            // เก็บเป็น string ตรงๆ ไม่แยก table
  university   String?
  instructor   String?
  price        Float             @default(0)
  status       String            @default("open")
  thumbnailUrl String?
  url          String            @unique  // link ไปมหาลัยจริง
  createdAt    DateTime          @default(now())
  keywords     CourseKeyword[]
  embedding    CourseEmbedding?
  interactions UserInteraction[]
  bookmarks    Bookmark[]
}


// COURSE KEYWORD  
// เก็บ tags ใช้ train recommend
model CourseKeyword {
  id       String @id @default(uuid())
  courseId String
  keyword  String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, keyword])
  @@index([courseId])
  @@index([keyword])
}


// COURSE EMBEDDING  
// vector สำหรับ recommend
model CourseEmbedding {
  id        String                     @id @default(uuid())
  courseId  String                     @unique
  embedding Unsupported("vector(1536)")
  course    Course                     @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}


// BOOKMARK 
model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  // bookmark ซ้ำไม่ได้
  @@unique([userId, courseId])  
  @@index([userId])
  @@index([courseId])
}


// USER INTERACTION 
// เก็บพฤติกรรม ใช้ปรับ UserInterest

model UserInteraction {
  id        String          @id @default(uuid())
  userId    String
  courseId  String
  action    InteractionType
  createdAt DateTime        @default(now())
  course    Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([courseId])
}


// USER INTEREST  (สรุปความสนใจ user → ใช้ recommend)
// score: bookmark = +3, click = +1, search = +1
model UserInterest {
  userId  String
  keyword String
  score   Float  @default(1)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, keyword])
  @@index([keyword])
}


// ENUMS
enum Role {
  admin
  student
}

enum InteractionType {
  // กดการ์ด
  click
  search   
  bookmark 
}
