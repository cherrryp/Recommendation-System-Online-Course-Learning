generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EducationLevel {
  SECONDARY
  HIGH_SCHOOL
  DIPLOMA
  BACHELOR
  MASTER
  DOCTORATE
  OTHER
}

model User {
  id       String @id @default(uuid())
  username String
  email    String @unique
  password String
  role     Role

  fname          String?
  lname          String?
  birthDate      DateTime?
  educationLevel EducationLevel?

  createdAt DateTime @default(now())

  enrollments     Enrollment[]
  feedbacks       Feedback[]
  certificates    Certificate[]
  recommendations RecommendationLog[]
  interests       UserInterest[]
  interactions    UserInteraction[]
}

enum Role {
  admin
  student
}

model Course {
  id String @id @default(uuid())

  courseName        String
  courseNameEn      String
  courseDescription String

  targetGroup  String?
  organization String?
  university   String?
  price        Float?

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  level Level

  thumbnailUrl String?

  embedding CourseEmbedding?

  createdAt DateTime @default(now())

  modules      Module[]
  keywords     CourseKeyword[]
  enrollments  Enrollment[]
  feedbacks    Feedback[]
  certificates Certificate[]
  interactions UserInteraction[]

  slug String @unique @db.VarChar(255)

  @@index([categoryId])
}

model Category {
  id   String @id @default(uuid())
  name String @unique

  course Course[]
}

enum Level {
  beginner
  intermediate
  advanced
}

model Instructor {
  id   String @id @default(uuid())
  name String

  organization String?
  title        String?

  lessons Lesson[]
}

// ------ เก็บส่วนสำคัญของเนื้อหาภายในคอร์สไว้สำหรับ search, recommendations ------
model CourseKeyword {
  id       String @id @default(uuid())
  courseId String
  keyword  String

  course Course @relation(fields: [courseId], references: [id])

  @@unique([courseId, keyword])
  @@index([courseId])
}

model Module {
  id                String  @id @default(uuid())
  courseId          String
  moduleName        String
  moduleDescription String?
  durationMin       Int
  orderIndex        Int

  course  Course   @relation(fields: [courseId], references: [id])
  lessons Lesson[]

  @@index([courseId])
}

model Lesson {
  id       String @id @default(uuid())
  moduleId String

  topicNo   String?
  topicName String
  videoUrl  String?

  module Module @relation(fields: [moduleId], references: [id])

  instructorId String?
  instructor   Instructor? @relation(fields: [instructorId], references: [id])

  performances LessonPerformance[]
  tests        Test[]

  @@index([moduleId])
}

model Enrollment {
  id String @id @default(uuid())

  userId   String
  courseId String

  status   EnrollmentStatus
  progress Float            @default(0)

  finalScore Float?

  enrolledDate DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  performances LessonPerformance[]

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

enum EnrollmentStatus {
  not_started
  in_progress
  completed
}

model LessonPerformance {
  id           String       @id @default(uuid())
  enrollmentId String
  lessonId     String
  quizScore    Float?
  timeSpentMin Float?
  lessonStatus LessonStatus

  updatedAt DateTime @updatedAt

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])
  lesson     Lesson     @relation(fields: [lessonId], references: [id])

  @@unique([enrollmentId, lessonId])
  @@index([lessonId])
}

enum LessonStatus {
  not_started
  in_progress
  completed
}

model Feedback {
  id       String @id @default(uuid())
  userId   String
  courseId String

  // ไม่ได้ fixed rating 1-5
  rating  Int
  comment String?

  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@index([courseId])
}

// ------ Test lesson ------ 
model Test {
  id       String @id @default(uuid())
  lessonId String

  question String

  optionA String
  optionB String
  optionC String
  optionD String

  correctAnswer String
  score         Int

  lesson Lesson @relation(fields: [lessonId], references: [id])

  @@index([lessonId])
}

model RecommendationLog {
  id                 String   @id @default(uuid())
  userId             String
  algorithm          String
  generatedAt        DateTime @default(now())
  recommendedCourses Json

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Certificate {
  id             String   @id @default(uuid())
  certificateId  String   @unique
  userId         String
  courseId       String
  issueDate      DateTime
  certificateUrl String

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])
}

model CourseEmbedding {
  id        String                @id @default(uuid())
  courseId  String                @unique
  embedding Unsupported("vector")

  course Course @relation(fields: [courseId], references: [id])

  @@index([courseId])
}

model UserInteraction {
  id        String          @id @default(uuid())
  userId    String
  courseId  String
  action    InteractionType
  createdAt DateTime        @default(now())

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@index([userId])
  @@index([courseId])
}

enum InteractionType {
  view
  click
  enroll
  complete
  like
  search
}

model UserInterest {
  userId  String
  keyword String

  user User @relation(fields: [userId], references: [id])

  @@id([userId, keyword])
  @@index([keyword])
}
